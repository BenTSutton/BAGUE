  m_Script: {fileID: 11500000, guid: 0c8ccbc6010c2234bb39781117f4cee9, type: 3}
  m_Name: Space crab
  m_EditorClassIdentifier: Assembly-CSharp::EventDefinition
  id: Space...Crustacean?
  displayName: Space...Crustacean?
  description: "Giant space crab\t"
  introText: 'A behemoth crustaceaous creature scuttles up to you out of the void
    of space. '
  choices:
  - choiceText: Thrusters set!  Jet off to the left to go around it.
    outcomeText: You enter a space gravity slipstream due to the size of the crab
      and are propelled away. +10 Fuel
    effects:
    - effectType: 2
      amount: 10
      stringValue: Fuel acquired.
  - choiceText: Engage the creature in combat.  You fear no crab.
    outcomeText: The crab opens its mouth and you see hundreds of needle like teeth
      that crunch your ship.  This crab fears no pirate. Health -10
    effects:
    - effectType: 1
      amount: 10
      stringValue: You lose to the crab.
